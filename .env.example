# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (production must use 256-bit key)
JWT_SECRET=knownote-dev-secret-key-change-in-production

# RocketMQ
ROCKETMQ_NAME_SERVER=localhost:9876

# Deep Research LLM (OpenAI 兼容接口)
RESEARCH_MODEL_ID=deepseek-chat
RESEARCH_MODEL_NAME=DeepSeek Chat
RESEARCH_MODEL=deepseek-chat
RESEARCH_MODEL_BASE_URL=https://api.deepseek.com
RESEARCH_MODEL_API_KEY=

# Tavily Search
TAVILY_API_KEY=

# Review AI (内容审核)
REVIEW_AI_ENABLED=true
REVIEW_AI_BASE_URL=https://api.deepseek.com
REVIEW_AI_API_KEY=
REVIEW_AI_MODEL=deepseek-chat

# OSS Storage (MinIO / S3 兼容)
OSS_ENDPOINT=http://localhost:9000
OSS_PUBLIC_URL=http://localhost:9000
OSS_PUBLIC_BUCKET=knownote-public
OSS_PRIVATE_BUCKET=knownote-private
OSS_ACCESS_KEY_ID=minioadmin
OSS_SECRET_ACCESS_KEY=minioadmin

# Email (Resend - 不配则验证码打印在日志中)
RESEND_API_KEY=
RESEND_FROM=

# Google OAuth (可选)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Timezone
TIME_TIMEZONE=Asia/Shanghai
